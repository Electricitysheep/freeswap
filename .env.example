# FreeSwap Configuration
# Copy to .env and fill in your API keys

# Master key for the proxy server
FREESWAP_MASTER_KEY=your-master-key-here

# Provider API Keys (uncomment and fill in what you need)
# GROQ_API_KEY=gsk_...
# GOOGLE_GEMINI_KEY=AIza...
# OPENROUTER_KEY=sk-or-...
# CEREBRAS_KEY=...
# MISTRAL_KEY=...
# NVIDIA_NIM_KEY=...
# CLOUDFLARE_KEY=...
# GITHUB_MODELS_KEY=ghp_...
# OLLAMA_BASE_URL=http://localhost:11434

# Multi-key rotation (comma-separated)
# GROQ_API_KEY=k1,k2,k3
# GOOGLE_GEMINI_KEY=k1,k2

# Server config
PORT=8080
HOST=127.0.0.1

# Routing config
DEFAULT_META_MODEL=free       # free, free-fast, free-smart
DEFAULT_FALLBACK_DEPTH=3      # How many fallback attempts
HEALTH_CHECK_INTERVAL_MS=300000  # 5 minutes

# Logging
LOG_LEVEL=info                 # debug, info, warn, error
